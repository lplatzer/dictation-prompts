{
  "name": "dictation-prompts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "SuperWhisper dictation cleanup modes, with sync, trace harvesting, and regression evals.",
  "scripts": {
    "cli": "bun run tools/cli.ts",
    "sync": "bun run tools/sync.ts",
    "harvest": "bun run trace/harvest.ts",
    "export": "bun run trace/export.ts",
    "eval": "bun run evals/run.ts",
    "build:mac": "bun build tools/cli.ts --compile --target=bun-darwin-arm64 --outfile dist/bin/dictation-macos",
    "build:win": "bun build tools/cli.ts --compile --target=bun-windows-x64 --outfile dist/bin/dictation-windows.exe"
  }
}
